# GoClaw v4 — E2E Test Environment
# Copy this file to .env and fill in actual API keys.
# .env is gitignored; .env.example is committed.

# ============================================================
# Database (local PG vector container — already running)
# ============================================================
GOCLAW_DATABASE_URL=postgres://dev:devpass@127.0.0.1:5435/goclaw_v4_e2e?sslmode=disable
GOCLAW_DB_HOST=127.0.0.1
GOCLAW_DB_PORT=5435
GOCLAW_DB_USER=dev
GOCLAW_DB_PASSWORD=devpass
GOCLAW_DB_NAME=goclaw_v4_e2e

# ============================================================
# Server
# ============================================================
GOCLAW_PORT=18790
GOCLAW_HOST=127.0.0.1
GOCLAW_LOG_LEVEL=debug

# ============================================================
# Migrations (use main migrations dir; v4 schema)
# ============================================================
GOCLAW_MIGRATIONS_DIR=./migrations

# ============================================================
# Encryption (AES-256-GCM for API keys, OAuth tokens, etc.)
# Generate via: openssl rand -hex 32
# ============================================================
GOCLAW_ENCRYPTION_KEY=REPLACE_WITH_HEX_32_BYTES

# ============================================================
# JWT signing (Q-B hybrid auth — JWT access + opaque refresh)
# Generate via: openssl rand -hex 32
# ============================================================
GOCLAW_JWT_SECRET=REPLACE_WITH_HEX_32_BYTES
GOCLAW_JWT_ACCESS_TTL=15m
GOCLAW_JWT_REFRESH_TTL=720h

# ============================================================
# Bootstrap root user (for E2E test seeding)
# ============================================================
E2E_ROOT_EMAIL=root@e2e.test
E2E_ROOT_PASSWORD=e2e-test-root-pass-changeme
E2E_ROOT_DISPLAY_NAME=E2E Root

# ============================================================
# LLM Provider API keys (for E2E API tests)
# Get from anh's secrets vault — DO NOT commit actual keys
# ============================================================
# Bailian = Alibaba Bailian Coding platform (provider_type "bailian", DashScope-compatible)
BAILIAN_API_KEY=REPLACE_WITH_BAILIAN_API_KEY
BAILIAN_API_BASE=https://coding-intl.dashscope.aliyuncs.com/v1
BAILIAN_DEFAULT_MODEL=qwen3.5-plus

OPENROUTER_API_KEY=REPLACE_WITH_OPENROUTER_API_KEY
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Default test models
E2E_MODEL_PROVIDER=openrouter
E2E_MODEL_NAME=anthropic/claude-sonnet-4-5

# ============================================================
# Test data isolation
# ============================================================
E2E_TEST_PREFIX=e2e
E2E_PARALLEL_USERS_PREFIX=u-
E2E_RANDOM_SUFFIX=true
